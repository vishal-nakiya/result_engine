NODE_ENV=development
PORT=4000

# Prisma (Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctgd?schema=public

# CORS (comma-separated)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# Uploads
MAX_UPLOAD_MB=25

