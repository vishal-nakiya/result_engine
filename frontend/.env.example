NEXT_PUBLIC_API_BASE=/api

# Optional (recommended on non-Vercel hosts):
# If NEXT_PUBLIC_API_BASE is relative ("/api"), server-side fetch will derive origin from:
# - NEXT_PUBLIC_SITE_URL / SITE_URL / NEXT_PUBLIC_APP_ORIGIN / APP_ORIGIN

# Optional (recommended everywhere):
# Use an absolute backend base for server-side rendering (avoids any proxy/rewrite issues).
# Example:
# API_SERVER_BASE=http://140.245.20.98:4500/api

